# Google Places API key (server-side — keep secret)
GOOGLE_MAPS_API_KEY=

# Same key exposed to client for Maps Embed iframe
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Supabase (shared foundation) --------------------------------------------
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Service-role key — server-side ONLY. Used by API routes to read/write the DB
# and upload to storage. Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Setup:
#   1. Create a Supabase project and paste the URL + service-role key above.
#   2. Run supabase/migrations/0001_foundation.sql in the SQL editor
#      (or `supabase db push`).
#   3. Create a public Storage bucket named `hotel-photos` for custom uploads.
